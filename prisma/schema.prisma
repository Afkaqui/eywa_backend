generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  superadmin
  admin
  gestor
  user
}

enum UserPlan {
  free
  premium
}

enum CourseLevel {
  basico
  intermedio
  avanzado
}

enum CourseCategory {
  agrotech
  edutech
  banca_sostenible
  esg
  general
}

enum RiskLevel {
  bajo
  medio
  alto
}

enum ValidationStatus {
  pending
  analyzing
  analyzed
  failed
}

// ─── Profiles ─────────────────────────────────────────────────────────────────

model Profile {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  fullName  String?  @map("full_name")
  company   String?
  password  String   // bcrypt hash
  role      UserRole @default(user)
  plan      UserPlan @default(free)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relaciones
  portfolioCompanies  PortfolioCompany[]
  diagnosticResults   DiagnosticResult[]
  diagnosticQuestions DiagnosticQuestion[]
  courses             Course[]
  enrollments         CourseEnrollment[]
  organization        Organization?
  simbiocreaciones    Simbiocreacion[]
  esgScore            EsgScore?
  esgHistory          EsgHistory[]
  projectPlans        ProjectPlan[]


  @@map("profiles")
}

// ─── Portfolio ────────────────────────────────────────────────────────────────

model PortfolioCompany {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  sector    String
  score     Int       @default(0)
  status    String    @default("Pendiente")
  carbon    String?
  trend     String?
  lastAudit String?   @map("last_audit")
  risk      RiskLevel @default(medio)
  createdBy String?   @map("created_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  creator Profile? @relation(fields: [createdBy], references: [id])

  @@map("portfolio_companies")
}

// ─── Diagnostic ───────────────────────────────────────────────────────────────

model DiagnosticQuestion {
  id                 String   @id @default(uuid()) @db.Uuid
  sortOrder          Int      @default(0) @map("sort_order")
  title              String
  description        String
  contextTitle       String?  @map("context_title")
  contextDescription String?  @map("context_description")
  contextImpact      String?  @map("context_impact")
  contextImage       String?  @map("context_image")
  createdBy          String?  @map("created_by") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  options   DiagnosticOption[]
  creator   Profile?           @relation(fields: [createdBy], references: [id])

  @@map("diagnostic_questions")
}

model DiagnosticOption {
  id         String @id @default(uuid()) @db.Uuid
  questionId String @map("question_id") @db.Uuid
  label      String
  value      String
  score      Int    @default(0)
  sortOrder  Int    @default(0) @map("sort_order")

  question DiagnosticQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("diagnostic_options")
}

model DiagnosticResult {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  score      Int
  maxScore   Int      @map("max_score")
  percentage Int
  level      String
  breakdown  Json     @default("[]")
  createdAt  DateTime @default(now()) @map("created_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("diagnostic_results")
}

// ─── Courses ──────────────────────────────────────────────────────────────────

model Course {
  id           String         @id @default(uuid()) @db.Uuid
  title        String
  description  String
  category     CourseCategory @default(general)
  level        CourseLevel    @default(basico)
  durationHours Int           @default(1) @map("duration_hours")
  imageUrl     String?        @map("image_url")
  instructor   String         @default("EYWA Academy")
  lessonsCount Int            @default(1) @map("lessons_count")
  isPublished  Boolean        @default(false) @map("is_published")
  createdBy    String?        @map("created_by") @db.Uuid
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  creator     Profile?          @relation(fields: [createdBy], references: [id])
  enrollments CourseEnrollment[]

  @@map("courses")
}

model CourseEnrollment {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  courseId    String    @map("course_id") @db.Uuid
  progress    Int       @default(0)
  completed   Boolean   @default(false)
  enrolledAt  DateTime  @default(now()) @map("enrolled_at")
  completedAt DateTime? @map("completed_at")

  user   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("course_enrollments")
}


// ─── Organization ─────────────────────────────────────────────────────────────

model Organization {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  type            String   @default("empresa")
  institutionType String?  @map("institution_type")
  name            String
  description     String?
  phone           String?
  website         String?
  externalLinks   Json     @default("[]") @map("external_links")
  country         String?
  sector          String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("organizations")
}

// ─── Simbiocreacion ───────────────────────────────────────────────────────────

model Simbiocreacion {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  nombre      String
  privado     Boolean  @default(false)
  lugar       String?
  fecha       String?
  horaInicio  String?  @map("hora_inicio")
  descripcion String?
  link        String?
  tags        Json     @default("[]")
  extraUrls   Json     @default("[]") @map("extra_urls")
  ods         Json     @default("[]")
  graphData   Json?    @map("graph_data")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("simbiocreaciones")
}

// ─── ESG Score ────────────────────────────────────────────────────────────────

model EsgScore {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  scores    Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("esg_scores")
}

model EsgHistory {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  scores    Json
  createdAt DateTime @default(now()) @map("created_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("esg_history")
}

// ─── Validador de Proyectos IA ─────────────────────────────────────────────────

model ProjectPlan {
  id           String           @id @default(uuid()) @db.Uuid
  userId       String           @map("user_id") @db.Uuid
  name         String
  type         String
  description  String
  budget       Int              @default(0)
  duration     Int              @default(0)
  carbonGoal   Int              @default(0) @map("carbon_goal")
  objectives   String?
  stakeholders String?
  documents    Json             @default("[]")
  status       ValidationStatus @default(pending)
  report       Json?
  analyzedAt   DateTime?        @map("analyzed_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("project_plans")
}
