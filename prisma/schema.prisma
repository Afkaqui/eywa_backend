generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  superadmin
  admin
  gestor
  user
}

enum UserPlan {
  free
  premium
}

enum CourseLevel {
  basico
  intermedio
  avanzado
}

enum CourseCategory {
  agrotech
  edutech
  banca_sostenible
  esg
  general
}

enum RiskLevel {
  bajo
  medio
  alto
}

enum ValidationStatus {
  pending
  analyzing
  analyzed
  failed
}

// ─── Profiles ─────────────────────────────────────────────────────────────────

model Profile {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  fullName  String?  @map("full_name")
  company   String?
  avatarUrl String?  @map("avatar_url") // ruta en disco del avatar (volumen VPS)
  password  String   // bcrypt hash
  role      UserRole @default(user)
  plan      UserPlan @default(free)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relaciones
  portfolioCompanies  PortfolioCompany[]
  diagnosticResults   DiagnosticResult[]
  diagnosticQuestions DiagnosticQuestion[]
  courses             Course[]
  enrollments         CourseEnrollment[]
  organization        Organization?
  simbiocreaciones    Simbiocreacion[]
  esgScore            EsgScore?
  esgHistory          EsgHistory[]
  projectPlans        ProjectPlan[]
  sectionProgress     SectionProgress[]
  examAttempts        ExamAttempt[]
  certificates        Certificate[]
  actors              Actor[]
  actorFavorites      ActorFavorite[]
  dataroomUploads     DataroomDocument[]


  @@map("profiles")
}

// ─── Actores (directorio del ecosistema) ──────────────────────────────────────

enum ActorCategory {
  proveedores_capital
  intermediarios
  bancos
  gobierno_multilaterales
  empresa_social
}

model Actor {
  id               String        @id @default(uuid()) @db.Uuid
  name             String
  country          String        // "PE" | "CO"
  category         ActorCategory
  subcategory      String?       // categoría/sub original de la fuente (trazabilidad)
  description      String?
  services         String?
  procedencia      String?       // Nacional / Internacional / Latino América
  geoScope         String?       @map("geo_scope") // Ámbito geográfico
  instruments      Json          @default("[]")    // string[]
  sectors          Json          @default("[]")    // string[]
  aum              String?       // activos de impacto bajo gestión (rango)
  investmentAmount String?       @map("investment_amount") // monto de inversión (rango)
  website          String?
  contactName      String?       @map("contact_name")  // PII — solo gestor/admin
  contactEmail     String?       @map("contact_email") // PII — solo gestor/admin
  source           String        // archivo/fuente de origen
  createdBy        String?       @map("created_by") @db.Uuid
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  creator Profile? @relation(fields: [createdBy], references: [id])

  @@unique([name, country])
  @@index([country])
  @@index([category])
  @@map("actors")

  favorites ActorFavorite[]
}

// Favorito de un usuario sobre un actor del directorio (el directorio es global y
// solo lo modifican admins/gestores; los favoritos SÍ son personales).
model ActorFavorite {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  actorId   String   @map("actor_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user  Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  actor Actor   @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@unique([userId, actorId])
  @@index([userId])
  @@map("actor_favorites")
}

// ─── Portfolio ────────────────────────────────────────────────────────────────

model PortfolioCompany {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  sector    String
  score     Int       @default(0)
  status    String    @default("Pendiente")
  carbon    String?
  trend     String?
  lastAudit String?   @map("last_audit")
  risk      RiskLevel @default(medio)
  createdBy String?   @map("created_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  creator Profile? @relation(fields: [createdBy], references: [id])

  @@map("portfolio_companies")
}

// ─── Diagnostic ───────────────────────────────────────────────────────────────

model DiagnosticQuestion {
  id                 String   @id @default(uuid()) @db.Uuid
  sortOrder          Int      @default(0) @map("sort_order")
  category           String   @default("general") // categoría GENES: perfil | ambiental | social | economico
  weight             Float    @default(0)          // peso del criterio (los pesos GENES suman 1.0)
  title              String
  description        String
  contextTitle       String?  @map("context_title")
  contextDescription String?  @map("context_description")
  contextImpact      String?  @map("context_impact")
  contextImage       String?  @map("context_image")
  createdBy          String?  @map("created_by") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  options   DiagnosticOption[]
  creator   Profile?           @relation(fields: [createdBy], references: [id])

  @@map("diagnostic_questions")
}

model DiagnosticOption {
  id         String @id @default(uuid()) @db.Uuid
  questionId String @map("question_id") @db.Uuid
  label      String
  value      String
  score      Int    @default(0)
  sortOrder  Int    @default(0) @map("sort_order")

  question DiagnosticQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("diagnostic_options")
}

model DiagnosticResult {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  score      Int
  maxScore   Int      @map("max_score")
  percentage Int
  level      String
  breakdown  Json     @default("[]")
  createdAt  DateTime @default(now()) @map("created_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("diagnostic_results")
}

// ─── Courses ──────────────────────────────────────────────────────────────────

model Course {
  id           String         @id @default(uuid()) @db.Uuid
  title        String
  description  String
  category     CourseCategory @default(general)
  level        CourseLevel    @default(basico)
  durationHours Int           @default(1) @map("duration_hours")
  imageUrl     String?        @map("image_url")
  instructor   String         @default("EYWA Academy")
  lessonsCount Int            @default(1) @map("lessons_count")
  isPublished  Boolean        @default(false) @map("is_published")
  passThreshold Int           @default(80) @map("pass_threshold") // % mínimo para aprobar el examen
  createdBy    String?        @map("created_by") @db.Uuid
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  creator       Profile?          @relation(fields: [createdBy], references: [id])
  enrollments   CourseEnrollment[]
  sections      CourseSection[]
  examQuestions ExamQuestion[]
  examAttempts  ExamAttempt[]
  certificates  Certificate[]

  @@map("courses")
}

// ─── Academia: secciones, examen y certificados ────────────────────────────────

model CourseSection {
  id          String   @id @default(uuid()) @db.Uuid
  courseId    String   @map("course_id") @db.Uuid
  sortOrder   Int      @default(0) @map("sort_order")
  title       String
  description String?
  videoUrl    String?  @map("video_url") // URL de YouTube
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  course    Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  resources SectionResource[]
  progress  SectionProgress[]

  @@index([courseId])
  @@map("course_sections")
}

model SectionResource {
  id        String @id @default(uuid()) @db.Uuid
  sectionId String @map("section_id") @db.Uuid
  type      String @default("link") // pdf | link | forum
  title     String
  url       String
  sortOrder Int    @default(0) @map("sort_order")

  section CourseSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@map("section_resources")
}

model SectionProgress {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  sectionId   String   @map("section_id") @db.Uuid
  completedAt DateTime @default(now()) @map("completed_at")

  user    Profile       @relation(fields: [userId], references: [id], onDelete: Cascade)
  section CourseSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([userId, sectionId])
  @@index([userId])
  @@map("section_progress")
}

model ExamQuestion {
  id           String @id @default(uuid()) @db.Uuid
  courseId     String @map("course_id") @db.Uuid
  sortOrder    Int    @default(0) @map("sort_order")
  question     String
  options      Json   @default("[]") // array de strings
  correctIndex Int    @map("correct_index") // NUNCA se envía al cliente

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@map("exam_questions")
}

model ExamAttempt {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  courseId   String   @map("course_id") @db.Uuid
  score      Int
  total      Int
  percentage Int
  passed     Boolean  @default(false)
  answers    Json     @default("{}") // { questionId: optionIndex }
  createdAt  DateTime @default(now()) @map("created_at")

  user   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([userId, courseId])
  @@map("exam_attempts")
}

model Certificate {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  courseId   String   @map("course_id") @db.Uuid
  code       String   @unique // código de verificación pública
  percentage Int
  issuedAt   DateTime @default(now()) @map("issued_at")

  user   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@map("certificates")
}

model CourseEnrollment {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  courseId    String    @map("course_id") @db.Uuid
  progress    Int       @default(0)
  completed   Boolean   @default(false)
  enrolledAt  DateTime  @default(now()) @map("enrolled_at")
  completedAt DateTime? @map("completed_at")

  user   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("course_enrollments")
}


// ─── Organization ─────────────────────────────────────────────────────────────

model Organization {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  type            String   @default("empresa")
  institutionType String?  @map("institution_type")
  name            String
  description     String?
  phone           String?
  website         String?
  externalLinks   Json     @default("[]") @map("external_links")
  country         String?
  sector          String?
  imageUrl        String?  @map("image_url") // ruta en disco del logo (volumen VPS)
  publicEnabled   Boolean  @default(false) @map("public_enabled") // mini-landing activa
  publicSlug      String?  @unique @map("public_slug")            // /empresa/<slug>
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user      Profile            @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents DataroomDocument[]

  @@map("organizations")
}

// ─── Dataroom ─────────────────────────────────────────────────────────────────
// Plantilla global (carpetas + documentos requeridos) que comparten todas las
// empresas; los archivos subidos cuelgan de la Organization del usuario.

model DataroomFolder {
  id          String  @id @default(uuid()) @db.Uuid
  key         String  @unique // panorama, legal, tributario…
  sortOrder   Int     @map("sort_order")
  name        String
  description String?

  items DataroomItem[]

  @@map("dataroom_folders")
}

model DataroomItem {
  id        String  @id @default(uuid()) @db.Uuid
  folderId  String  @map("folder_id") @db.Uuid
  sortOrder Int     @map("sort_order")
  name      String  // "Ficha RUC", "Reporte de sostenibilidad"…
  hint      String? // ayuda opcional

  folder    DataroomFolder     @relation(fields: [folderId], references: [id], onDelete: Cascade)
  documents DataroomDocument[]

  @@index([folderId])
  @@map("dataroom_items")
}

model DataroomDocument {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  itemId         String   @map("item_id") @db.Uuid
  fileName       String   @map("file_name")    // nombre original
  storagePath    String   @map("storage_path") // ruta en el disco del VPS
  mime           String
  size           Int
  isPublic       Boolean  @default(false) @map("is_public") // nace PRIVADO siempre
  uploadedBy     String?  @map("uploaded_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item         DataroomItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  uploader     Profile?     @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([itemId])
  @@map("dataroom_documents")
}

// ─── Simbiocreacion ───────────────────────────────────────────────────────────

model Simbiocreacion {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  nombre      String
  privado     Boolean  @default(false)
  lugar       String?
  fecha       String?
  horaInicio  String?  @map("hora_inicio")
  descripcion String?
  link        String?
  tags        Json     @default("[]")
  extraUrls   Json     @default("[]") @map("extra_urls")
  ods         Json     @default("[]")
  graphData   Json?    @map("graph_data")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("simbiocreaciones")
}

// ─── ESG Score ────────────────────────────────────────────────────────────────

model EsgScore {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  scores    Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("esg_scores")
}

model EsgHistory {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  scores    Json
  createdAt DateTime @default(now()) @map("created_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("esg_history")
}

// ─── Validador de Proyectos IA ─────────────────────────────────────────────────

model ProjectPlan {
  id           String           @id @default(uuid()) @db.Uuid
  userId       String           @map("user_id") @db.Uuid
  name         String
  type         String
  description  String
  budget       Int              @default(0)
  duration     Int              @default(0)
  carbonGoal   Int              @default(0) @map("carbon_goal")
  objectives   String?
  stakeholders String?
  documents    Json             @default("[]")
  status       ValidationStatus @default(pending)
  report       Json?
  analyzedAt   DateTime?        @map("analyzed_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("project_plans")
}
