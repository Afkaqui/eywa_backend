# ═══════════════════════════════════════════════════════════════════════════════
# PLANTILLA de variables de entorno — eywa_api
#
# Este archivo SÍ se commitea y el repositorio es PÚBLICO.
# ⚠️  NUNCA escribas valores reales aquí. Solo marcadores de posición.
#     Los valores de verdad van en `.env` (ignorado por git) o en el `.env` del VPS.
#
# Uso: cp .env.example .env  →  y completa los valores en `.env`
# ═══════════════════════════════════════════════════════════════════════════════

# ── Base de datos ─────────────────────────────────────────────────────────────
# En el VPS, Postgres escucha SOLO en 127.0.0.1 (no accesible desde fuera).
# Para desarrollo local: levanta un Postgres propio, o abre un túnel SSH:
#   ssh -L 5432:127.0.0.1:5432 usuario@servidor
DATABASE_URL=postgresql://USUARIO:CONTRASENA@localhost:5432/eywa_db

# ── Auth ──────────────────────────────────────────────────────────────────────
# DEBE ser exactamente el mismo valor que AUTH_SECRET en eywa_frontend,
# o los tokens que emite el frontend no validarán aquí.
# Generar con: openssl rand -base64 32
AUTH_SECRET=GENERA_UN_SECRETO_DE_32_CARACTERES

# ── CORS ──────────────────────────────────────────────────────────────────────
# Orígenes permitidos, separados por coma.
CORS_ORIGIN=https://tu-dominio.com,http://localhost:3000

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=4001
NODE_ENV=development

# ── Almacenamiento de archivos ────────────────────────────────────────────────
# En el VPS es un volumen montado desde el host (sobrevive a los redeploys).
UPLOAD_DIR=/app/uploads

# ── Validador de Proyectos · IA (OPCIONAL) ────────────────────────────────────
# Si estas variables están vacías, el validador usa un heurístico determinista.
# Funciona con cualquier API compatible con OpenAI (/chat/completions).
#
# Ejemplo con Groq:
#   VALIDATOR_AI_URL=https://api.groq.com/openai/v1/chat/completions
#   VALIDATOR_AI_MODEL=openai/gpt-oss-120b
#
# ⚠️  La clave NUNCA se escribe en este archivo: va en `.env` (local) o en el
#     `.env` del VPS, ninguno de los dos versionado.
VALIDATOR_AI_URL=
VALIDATOR_AI_KEY=
VALIDATOR_AI_MODEL=
