# ── Base de datos ─────────────────────────────────────────────────────────────
# Producción (VPS):
DATABASE_URL=postgresql://admin:K4qu1_Pr0d_2026@161.132.54.226:5432/eywa_db
# Desarrollo local (apunta al VPS o a un docker local):
# DATABASE_URL=postgresql://admin:password@localhost:5432/eywa_db

# ── Auth ──────────────────────────────────────────────────────────────────────
# DEBE ser el mismo valor que AUTH_SECRET en eywa_frontend
# Generar con: openssl rand -base64 32
AUTH_SECRET=cambia-esto-por-un-secreto-de-32-caracteres

# ── CORS ──────────────────────────────────────────────────────────────────────
# Orígenes permitidos separados por coma
CORS_ORIGIN=https://eywa.com,http://localhost:3000

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=4001
NODE_ENV=development

# ── Validador de Proyectos IA ───────────────────────────────────────────────────
# Credenciales de la API de IA (las proveerá ARS). Mientras estén vacías, el
# validador usa un análisis heurístico determinista como fallback.
# VALIDATOR_AI_URL=https://api.proveedor-ia.com/v1/chat/completions
# VALIDATOR_AI_KEY=
# VALIDATOR_AI_MODEL=
